{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sarahewilkerson/fedresearch-dictionary-extractor/schema/definition-output-v1.json",
  "title": "FedResearch definition extraction output (schema v1)",
  "type": "object",
  "required": [
    "schema_version",
    "source_pdf",
    "extractor_version",
    "profile",
    "entries",
    "metadata"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "source_pdf": { "type": "string" },
    "source_gcs_key": { "type": ["string", "null"] },
    "source_doc_id": { "type": ["string", "null"] },
    "source_pub_number": { "type": ["string", "null"] },
    "source_doc_type": { "type": ["string", "null"] },
    "extractor_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+" },
    "extraction_timestamp": { "type": "string", "format": "date-time" },
    "profile": { "type": "string" },
    "text_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$|^$" },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/Entry" }
    },
    "metadata": { "$ref": "#/$defs/Metadata" }
  },
  "$defs": {
    "Entry": {
      "type": "object",
      "required": [
        "term",
        "term_normalized",
        "definition",
        "source_type",
        "pdf_page_index"
      ],
      "properties": {
        "term": { "type": "string", "minLength": 1, "maxLength": 500 },
        "term_normalized": { "type": "string", "minLength": 1, "maxLength": 500 },
        "definition": { "type": "string", "minLength": 1, "maxLength": 10000 },
        "source_type": { "enum": ["glossary", "inline"] },
        "section": { "type": ["string", "null"] },
        "pdf_page_index": { "type": "integer", "minimum": 1 },
        "printed_page_label": { "type": ["string", "null"] },
        "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "flags": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "Metadata": {
      "type": "object",
      "required": ["total_pages", "text_layer_present", "entries_glossary", "entries_inline", "entries_after_dedup"],
      "properties": {
        "total_pages": { "type": "integer", "minimum": 0 },
        "glossary_pages": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "text_layer_present": { "type": "boolean" },
        "entries_glossary": { "type": "integer", "minimum": 0 },
        "entries_inline": { "type": "integer", "minimum": 0 },
        "entries_after_dedup": { "type": "integer", "minimum": 0 },
        "section_structure": {
          "description": "Unit 2 of v0.2.0: detection-only Section I/II structure label. Optional; not all extractor versions emit this field.",
          "enum": ["none", "section_i_only", "section_ii_only", "both", "unknown"]
        },
        "section_ii_pages": {
          "description": "Unit 3 of v0.2.0: 1-based narrowed page range when Section II scoping fired. Null when narrowing didn't fire.",
          "type": ["array", "null"],
          "items": { "type": "integer", "minimum": 1 }
        },
        "section_ii_narrowing_attempted": {
          "description": "Unit 3 of v0.2.0: True when section_structure ∈ {both, section_ii_only} and narrowing was attempted.",
          "type": "boolean"
        },
        "section_ii_narrowing_fired": {
          "description": "Unit 3 of v0.2.0: True when narrowing produced a non-empty narrowed range. attempted=True + fired=False is the identity-fallback case.",
          "type": "boolean"
        },
        "section_ii_boundary_scan_errors": {
          "description": "Unit 3 of v0.2.0: count of pages that errored during the forward scan for SECTION_AFTER_II_HEADER. > 0 flags doc for review.",
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
